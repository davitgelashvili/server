PORT=5001
# NODE_ENV=production
NODE_ENV=development

ALLOWED_ORIGINS=https://yourdomain.ge,https://www.yourdomain.ge

DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

JWT_ACCESS_SECRET=change_me_to_a_random_64_char_hex
JWT_REFRESH_SECRET=change_me_to_a_random_64_char_hex

ACCESS_TTL=15m
REFRESH_TTL_DAYS=30

COOKIE_SECURE=true
COOKIE_SAMESITE=strict

TKT_EXPORT_KEY=change_me

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=YourAppName
